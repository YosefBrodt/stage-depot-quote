# Required: shared password gate. Set the same value in Vercel project settings.
APP_PASSWORD=change-me

# Required: 32+ char random secret used to sign session cookies. Set in Vercel too.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# Vercel Postgres (auto-injected when you attach the database in the Vercel dashboard).
# Locally, run `vercel env pull` after attaching the DB to populate these.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
